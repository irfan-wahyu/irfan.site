---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id.replace(/\.md$/, '') }, 
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;

const { title, subtitle, year, duration, status, medium, tools, tags, thumbnail, raw_asset_url } = data;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${title} — Irfan Wahyu`} description={subtitle}>
  <style is:global>
    @import '../../../public/styles/work-detail.css';
    
    .article h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 500;
      font-style: italic;
      color: var(--text);
      line-height: 1.2;
      margin-top: var(--space-2xl);
      margin-bottom: var(--space-md);
      padding-top: var(--space-md);
      border-top: 1px solid var(--border);
      position: relative;
    }
    
    .article h2::before {
      content: '';
      position: absolute;
      top: -1px;
      left: 0;
      width: 40px;
      height: 1px;
      background: var(--accent);
    }
    
    .article h2:first-child {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }
    
    .article h2:first-child::before {
      display: none;
    }
    
    .article h3 {
      font-family: var(--font-heading);
      font-size: clamp(1.1rem, 1.8vw, 1.4rem);
      font-weight: 400;
      font-style: italic;
      color: var(--text-muted);
      line-height: 1.3;
      margin-top: var(--space-lg);
      margin-bottom: var(--space-sm);
    }
    
    .article p {
      font-family: var(--font-body);
      font-size: .92rem;
      color: var(--text-muted);
      line-height: 1.95;
      margin-bottom: var(--space-md);
      font-weight: 300;
    }
    
    .article p strong {
      color: var(--text);
      font-weight: 500;
    }
    
    .article blockquote {
      border-left: 2px solid var(--accent);
      padding: var(--space-sm) var(--space-md);
      margin: var(--space-lg) 0;
      background: var(--bg-secondary);
      border-radius: 0 8px 8px 0;
    }
    
    .article blockquote p {
      font-family: var(--font-heading);
      font-size: 1.05rem;
      font-style: italic;
      color: var(--text);
      opacity: .85;
      margin: 0;
      line-height: 1.7;
    }

    .masonry-gallery-grid {
      display: grid !important;
      gap: 16px !important;
      margin: 32px 0 !important;
      width: 100% !important;
    }

    .masonry-gallery-grid img {
      width: 100% !important;
      height: auto !important;
      object-fit: contain !important;
      margin: 0 !important;
    }

    @media (max-width: 600px) {
      .masonry-gallery-grid {
        grid-template-columns: 1fr !important;
        gap: 12px !important;
      }
    }

    .sidebar-toc {
      max-height: 380px !important;
      display: flex !important;
      flex-direction: column !important;
      padding: 20px var(--space-md) var(--space-md) var(--space-md) !important;
    }

    .toc-list {
      flex: 1 !important;
      overflow-y: auto !important;
      overflow-x: hidden !important;
      padding-right: 4px !important;
    }

    .toc-item a {
      font-size: 0.95rem !important;
      padding: 6px 12px !important;
    }

    .toc-item.toc-h3 a {
      font-size: 0.88rem !important;
    }

    .toc-list::-webkit-scrollbar {
      width: 4px !important;
    }
    .toc-list::-webkit-scrollbar-track {
      background: transparent !important;
    }
    .toc-list::-webkit-scrollbar-thumb {
      background: var(--accent) !important;
      border-radius: 2px !important;
    }

    .sidebar-back {
      color: var(--accent) !important;
      font-weight: 500 !important;
      transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;
    }

    .sidebar-back:hover {
      color: #e4e0d8 !important;
      transform: translateX(-4px) !important;
    }

    .sidebar-back svg {
      transition: transform 0.3s ease !important;
    }

    .sidebar-back:hover svg {
      transform: translateX(-2px) !important;
    }
  </style>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lbClose">✕</button>
    <button class="lightbox-nav lightbox-prev" id="lbPrev">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
    </button>
    <button class="lightbox-nav lightbox-next" id="lbNext">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
    </button>
    <div class="lightbox-img-wrap">
      <img id="lbImg" src="" alt="" />
    </div>
    <div class="lightbox-counter" id="lbCounter"></div>
    <div class="lightbox-caption" id="lbCaption"></div>
  </div>

  <Nav variant="detail" />

  <section id="project-hero" class="has-corners" style="position: relative; overflow: hidden;">
    <span class="c-tl"></span><span class="c-tr"></span>
    <div class="hero-bg-fill"></div>
    <div class="hero-bg-texture"></div>
    
    {thumbnail && (
      <img 
        src={thumbnail.startsWith('http') || thumbnail.startsWith('/') 
          ? thumbnail 
          : `${base}images/${thumbnail}`} 
        alt={title}
        style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; filter: brightness(0.4);" 
      />
    )}

    <div class="hero-bg" style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 20%, var(--bg) 100%); z-index: 1; pointer-events: none;"></div>

    <div class="hero-content" style="position: relative; z-index: 10; display: flex; flex-direction: column; align-items: flex-start; gap: 8px !important; padding-top: var(--space-xl) !important; padding-bottom: var(--space-md) !important;">
      <h1 class="project-title" style="margin-bottom: 0 !important; line-height: 1.15;" set:html={title.replace('—', '<br>—')} />
      {subtitle && <p class="project-subtitle" style="margin-top: 0 !important; margin-bottom: 4px !important; opacity: 0.8;">{subtitle}</p>}

      {raw_asset_url && (
        <a 
          href={raw_asset_url}
          target="_blank" 
          rel="noopener noreferrer"
          class="hero-static-asset-btn"
          title="Open working asset file"
        >
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
          VIEW_ASSET
        </a>
      )}
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  <div id="project-body">
    <aside class="sidebar">
      <a href="/irfan.site/works" class="sidebar-back fade-in" data-delay="160">
        <svg width="12" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M13 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Semua Works
      </a>
      
      <div class="sidebar-stats fade-in">
        <div class="toc-label" style="margin-bottom: 10px !important; opacity: 0.7;">
          Project Information
        </div>

        <div class="stat-item">
          <span class="stat-label">Tahun</span>
          <span class="stat-value">{year}</span>
        </div>
        {duration && (
          <div class="stat-item">
            <span class="stat-label">Durasi</span>
            <span class="stat-value">{duration}</span>
          </div>
        )}
        <div class="stat-item">
          <span class="stat-label">Status</span>
          <span class="stat-value">{status}</span>
        </div>
        {medium && (
          <div class="stat-item">
            <span class="stat-label">Medium</span>
            <span class="stat-value">{medium}</span>
          </div>
        )}
        {tools.length > 0 && (
          <div class="stat-item">
            <span class="stat-label">Tools</span>
            <div class="stat-tags">
              {tools.map(tool => <span class="stat-tag">{tool}</span>)}
            </div>
          </div>
        )}
      </div>

      <div class="sidebar-toc fade-in" data-delay="80">
        <div class="toc-label">Table of Contents</div>
        <ul class="toc-list" id="tocList"></ul>
      </div>
    </aside>

    <article class="article">
      <Content />
    </article>
  </div>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  <style>
    .hero-static-asset-btn {
      font-family: var(--font-mono); 
      font-size: 0.58rem; 
      color: var(--accent); 
      text-decoration: none; 
      border: 1px solid rgba(201, 169, 110, 0.4); 
      padding: 5px 12px; 
      border-radius: 4px; 
      display: inline-flex; 
      align-items: center; 
      gap: 6px; 
      letter-spacing: 0.08em; 
      background: rgba(12, 14, 19, 0.6); 
      backdrop-filter: blur(4px); 
      transition: all 0.3s ease; 
      margin-top: 6px; 
      pointer-events: auto !important;
    }
    .hero-static-asset-btn:hover {
      background: var(--accent) !important;
      color: var(--bg) !important;
    }
  </style>

  <script>
    function forceLongImageStyles() {
      const article = document.querySelector('.article');
      if (!article) return;
      
      const imgs = article.querySelectorAll('img');
      imgs.forEach((img) => {
        const titleText = img.getAttribute('title') || '';
        const altText = img.getAttribute('alt') || '';
        
        if (titleText.includes('long') || altText.includes('long')) {
          img.style.setProperty('width', '100%', 'important');
          img.style.setProperty('min-width', '100%', 'important');
          img.style.setProperty('max-width', '100%', 'important');
          img.style.setProperty('height', 'auto', 'important');
          img.style.setProperty('max-height', 'none', 'important');
          img.style.setProperty('object-fit', 'fill', 'important');
          img.style.setProperty('margin', '0 auto', 'important');
          img.style.setProperty('border-radius', '4px', 'important');

          const parent = img.parentElement;
          if (parent) {
            parent.style.setProperty('display', 'block', 'important');
            parent.style.setProperty('width', '100%', 'important');
            parent.style.setProperty('max-width', '720px', 'important');
            parent.style.setProperty('height', 'auto', 'important');
            parent.style.setProperty('max-height', '650px', 'important');
            parent.style.setProperty('overflow-y', 'auto', 'important');
            parent.style.setProperty('overflow-x', 'hidden', 'important');
            parent.style.setProperty('background', '#111419', 'important');
            parent.style.setProperty('border', '1px solid rgba(228, 224, 216, 0.07)', 'important');
            parent.style.setProperty('padding', '12px', 'important');
            parent.style.setProperty('margin', '32px auto', 'important');
          }
        }
      });
    }

    function initGallerySystems() {
      const article = document.querySelector('.article');
      if (!article) return;

      const children = Array.from(article.children);
      let tempGroup = [];
      let currentColumns = 2;

      children.forEach((el, index) => {
        const img = el.tagName === 'P' && el.children.length === 1 && el.children[0].tagName === 'IMG' 
          ? el.children[0] 
          : (el.tagName === 'IMG' ? el : null);

        if (img) {
          const titleText = img.getAttribute('title') || '';
          const match = titleText.match(/:([2-4])/);
          if (match && tempGroup.length === 0) {
            currentColumns = parseInt(match[1]);
            img.setAttribute('title', titleText.replace(/:[2-4]/, '').trim());
          }
          
          tempGroup.push({ pElement: el.tagName === 'P' ? el : null, imgElement: img });
        } else {
          if (tempGroup.length >= 2) buildGrid(tempGroup, currentColumns);
          tempGroup = [];
          currentColumns = 2;
        }

        if (index === children.length - 1 && tempGroup.length >= 2) {
          buildGrid(tempGroup, currentColumns);
        }
      });

      function buildGrid(group, columns) {
        const gridDiv = document.createElement('div');
        gridDiv.className = 'masonry-gallery-grid';
        gridDiv.style.gridTemplateColumns = `repeat(${columns}, 1fr)`;

        const firstTarget = group[0].pElement || group[0].imgElement;
        firstTarget.parentNode.insertBefore(gridDiv, firstTarget);

        group.forEach(item => {
          gridDiv.appendChild(item.imgElement);
          if (item.pElement && item.pElement.parentNode) {
            item.pElement.parentNode.removeChild(item.pElement);
          }
        });
      }

      forceLongImageStyles();

      const observer = new MutationObserver(() => {
        forceLongImageStyles();
      });
      observer.observe(article, { childList: true, subtree: true });

      const lb = document.getElementById('lightbox');
      const lbImg = document.getElementById('lbImg') as HTMLImageElement;
      const lbCaption = document.getElementById('lbCaption');
      const lbCounter = document.getElementById('lbCounter');
      if (!lb || !lbImg) return;
      
      let images = [];
      let current = 0;

      const allArticleImages = article.querySelectorAll('img');
      if (allArticleImages.length === 0) return;

      allArticleImages.forEach((img: HTMLImageElement, i) => {
        images.push({ src: img.src, alt: img.getAttribute('title') || img.alt || '' });
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => open(i));
      });

      function open(i) {
        current = i;
        lbImg.style.transform = 'scale(0.85)';
        lbImg.style.opacity = '0';
        lbImg.style.filter = 'blur(8px)';
        
        lbImg.src = images[i].src;
        if (lbCaption) lbCaption.textContent = images[i].alt || '';
        if (lbCounter) lbCounter.textContent = (i + 1) + ' / ' + images.length;
        
        lb.classList.add('open');
        
        const imgWrap = document.querySelector('.lightbox-img-wrap');
        if (imgWrap) imgWrap.scrollTop = 0;
        
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            lbImg.style.transform = '';
            lbImg.style.opacity = '';
            lbImg.style.filter = '';
          });
        });
      }

      function close() { 
        lbImg.style.transform = 'scale(0.85)';
        lbImg.style.opacity = '0';
        lbImg.style.filter = 'blur(8px)';
        setTimeout(() => {
          lb.classList.remove('open');
          lbImg.src = ''; 
        }, 350);
      }

      document.getElementById('lbClose')?.addEventListener('click', close);
      document.getElementById('lbPrev')?.addEventListener('click', () => open((current - 1 + images.length) % images.length));
      document.getElementById('lbNext')?.addEventListener('click', () => open((current + 1) % images.length));
      
      lb.addEventListener('click', e => { if (e.target === lb) close(); });
      
      document.removeEventListener('keydown', handleKeyDown);
      document.addEventListener('keydown', handleKeyDown);

      function handleKeyDown(e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') open((current - 1 + images.length) % images.length);
        if (e.key === 'ArrowRight') open((current + 1) % images.length);
      }
    }

    function initToc() {
      const article = document.querySelector('.article');
      const tocList = document.getElementById('tocList');
      if (!article || !tocList) return;
      tocList.innerHTML = '';
      const headings = article.querySelectorAll('h2, h3');
      if (!headings.length) return;
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'section-' + i;
        const li = document.createElement('li');
        li.className = 'toc-item ' + (h.tagName === 'H3' ? 'toc-h3' : 'toc-h2');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent || '';
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.getElementById(h.id);
          if (target) window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 120, behavior: 'smooth' });
        });
        li.appendChild(a);
        tocList.appendChild(li);
      });
      const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocList.querySelectorAll('a').forEach(a => {
              a.classList.toggle('active', a.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
      headings.forEach(h => io.observe(h));
    }

    function initScrollFade() {
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0');
          setTimeout(() => el.classList.add('visible'), delay);
          io.unobserve(el);
        });
      }, { threshold: .08 });
      document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => { initGallerySystems(); initToc(); initScrollFade(); }, 100);
      });
    } else {
      setTimeout(() => { initGallerySystems(); initToc(); initScrollFade(); }, 100);
    }
  </script>
</Layout>