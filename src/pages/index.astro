      else{setTimeout(()=>{cur.style.opacity='0';cur.style.transition='opacity .5s'},400)}
    }
  }
  setTimeout(type,800);
})();

// WORD-BLUR for section headings — safe DOM walk, preserves em/br
function wrapSentences(el,lineDelay){
  // Get plain text, split into chunks by sentence-ending punctuation
  const raw=el.textContent.trim();
  // Split on ". " or ", " keeping delimiter attached to previous chunk
  const chunks=raw.match(/[^,\.]+[,\.]?\s*/g)||[raw];
  // Group into pairs for better visual chunking (avoid too many tiny lines)
  const groups=[];
  for(let i=0;i<chunks.length;i+=2){
    const g=chunks.slice(i,i+2).join('').trim();
    if(g)groups.push(g);
  }
  let html='';
  groups.forEach((g,i)=>{
    html+=`<span class="sentence-unit" style="display:block;opacity:0;filter:blur(6px);transform:translateY(12px);transition:opacity .7s ease ${i*lineDelay}ms,filter .7s ease ${i*lineDelay}ms,transform .7s ease ${i*lineDelay}ms">${g}</span>`;
  });
  el.innerHTML=html;
  // Store groups count for observer
  el.dataset.sentenceCount=groups.length;
}

function wrapHeadingWords(el,wordDelay){
  // Walk text nodes only, wrap each word
  function walk(node){
    if(node.nodeType===3){
      // text node — split into words
      const words=node.textContent.split(/(\s+)/);
      if(words.length<=1&&!words[0].trim())return;
      const frag=document.createDocumentFragment();
      words.forEach(w=>{
        if(!w.trim()){
          frag.appendChild(document.createTextNode(w));
        } else {
          const s=document.createElement('span');
          s.className='word-unit';
          s.textContent=w;
          frag.appendChild(s);
        }
      });
      node.parentNode.replaceChild(frag,node);
    } else if(node.nodeType===1&&node.nodeName!=='SCRIPT'&&node.nodeName!=='STYLE'){
      Array.from(node.childNodes).forEach(walk);
    }
  }
  walk(el);
  // Assign staggered delays
  el.querySelectorAll('.word-unit').forEach((w,i)=>{
    w.style.transitionDelay=(i*wordDelay)+'ms';
  });
}

// SCROLL ANIMATIONS
(function(){
  // Setup heading-anim elements
  document.querySelectorAll('.heading-anim').forEach(el=>{
    if(el.classList.contains('slide-quote')){
      // Per-sentence/line reveal for philosophy quote
      wrapSentences(el,180);
    } else {
      wrapHeadingWords(el,120);
    }
  });

  function reveal(entries,obs){
    entries.forEach(e=>{
      if(!e.isIntersecting)return;
      const el=e.target;
      // heading words or sentences
      if(el.classList.contains('heading-anim')){
        // word-unit or sentence-unit
        el.querySelectorAll('.word-unit,.sentence-unit').forEach(w=>{
          w.style.opacity='1';
          w.style.filter='blur(0)';
          w.style.transform='translateY(0)';
        });
        obs.unobserve(el);return;
      }
      // staggered items
      const delay=parseInt(el.dataset.delay||0);
      setTimeout(()=>el.classList.add('visible'),delay);
      obs.unobserve(el);
    });
  }

  const io=new IntersectionObserver(reveal,{threshold:.08,rootMargin:'0px 0px -30px 0px'});

  document.querySelectorAll('.fade-in').forEach(el=>io.observe(el));
  document.querySelectorAll('.heading-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.card-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.work-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.slide-left').forEach(el=>io.observe(el));
})();
  </script>
