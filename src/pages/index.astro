// TYPING EFFECT
(function(){
  const el=document.querySelector('.hero-heading');
  if(!el)return;
  const full1='Lagi Debugging Bang.'; const full2='Nanti Klo Udh Ga Ngebug.';
  el.innerHTML='';
  const line1=document.createElement('span'); const br=document.createElement('br'); const em=document.createElement('em'); const cur=document.createElement('span');
  cur.className='typing-cursor'; el.appendChild(line1);el.appendChild(br);el.appendChild(em);el.appendChild(cur);
  let i=0,phase=0; const speed=48;
  function type(){
    if(phase===0){
      if(i<=full1.length){line1.textContent=full1.slice(0,i);i++;setTimeout(type,speed)}
      else{i=0;phase=1;setTimeout(type,280)}
    } else {
      if(i<=full2.length){em.textContent=full2.slice(0,i);i++;setTimeout(type,speed)}
      else{setTimeout(()=>{cur.style.opacity='0';cur.style.transition='opacity .5s'},400)}
    }
  }
  setTimeout(type,800);
})();

// STRUKTUR DATA WRAPPER ANIMASI SINKRON
function wrapSentences(el:any,lineDelay:number){
  const raw=el.textContent.trim();
  const chunks=raw.match(/[^,\.]+[,\.]?\s*/g)||[raw];
  const groups:any=[];
  for(let i=0;i<chunks.length;i+=2){
    const g=chunks.slice(i,i+2).join('').trim();
    if(g)groups.push(g);
  }
  let html='';
  groups.forEach((g:any,i:number)=>{
    html+=`<span class="sentence-unit" style="display:block; transition-delay: ${i*lineDelay}ms;">${g}</span>`;
  });
  el.innerHTML=html;
}

function wrapHeadingWords(el:any,wordDelay:number){
  function walk(node:any){
    if(node.nodeType===3){
      const words=node.textContent.split(/(\s+)/);
      if(words.length<=1&&!words[0].trim())return;
      const frag=document.createDocumentFragment();
      words.forEach((w:any)=>{
        if(!w.trim()){ frag.appendChild(document.createTextNode(w)); } 
        else {
          const s=document.createElement('span'); s.className='word-unit'; s.textContent=w; frag.appendChild(s);
        }
      });
      node.parentNode.replaceChild(frag,node);
    } else if(node.nodeType===1&&node.nodeName!=='SCRIPT'&&node.nodeName!=='STYLE'){
      Array.from(node.childNodes).forEach(walk);
    }
  }
  walk(el);
  el.querySelectorAll('.word-unit').forEach((w:any,i:number)=>{
    w.style.transitionDelay=(i*wordDelay)+'ms';
  });
}

// SCROLL ANIMATIONS (FUSION INTERSECTION OBSERVER PINTAR)
// SCROLL ANIMATIONS
(function(){
  document.querySelectorAll('.heading-anim').forEach(el=>{
    // PERBAIKAN: Jika mengandung slide-quote ATAU about-text-fade, pecah teksnya per kalimat
    if(el.classList.contains('slide-quote') || el.classList.contains('about-text-fade')){ 
      wrapSentences(el, 220); 
    } 
    else { 
      wrapHeadingWords(el, 100); 
    }
  });

  function reveal(entries:any,obs:any){
    entries.forEach((e:any)=>{
      if(!e.isIntersecting)return;
      const el=e.target;
      
      // 1. Eksekusi Teks Animasi Kata / Kalimat (Blur Fade Up)
      if(el.classList.contains('heading-anim')){
        el.querySelectorAll('.word-unit,.sentence-unit').forEach((w:any)=>{
          w.style.opacity='1'; w.style.filter='blur(0)'; w.style.transform='translateY(0)';
        });
        obs.unobserve(el); return;
      }
      
      // 2. Eksekusi Node Roadmap (Fade Up Santai Berurutan)
      if(el.classList.contains('roadmap-node')){
        const d = parseInt(el.dataset.delay || '0');
        setTimeout(() => el.classList.add('visible'), d);
        obs.unobserve(el); return;
      }

      // 3. Eksekusi Komponen Standar / Boks Info / Praktek Kartu
      const delay=parseInt(el.dataset.delay||0);
      setTimeout(()=>el.classList.add('visible'),delay);
      obs.unobserve(el);
    });
  }

  const io=new IntersectionObserver(reveal,{threshold:.05, rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.fade-in').forEach(el=>io.observe(el));
  document.querySelectorAll('.heading-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.card-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.work-anim').forEach(el=>io.observe(el));
  document.querySelectorAll('.about-info-card').forEach(el=>io.observe(el));
  document.querySelectorAll('.roadmap-node').forEach(el=>io.observe(el));
})();
  </script>
