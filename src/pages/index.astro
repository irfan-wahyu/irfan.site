  </div>
  <div class="works-grid" id="worksGrid">
    {sorted.map((project, idx) => (
      <a href={`${base}works/${project.id}/`} class={`work-card work-anim${idx >= 3 ? ' hidden' : ''}`} data-delay={idx >= 3 ? '0' : String(idx * 100)}>
        <div class="work-placeholder">
          <div class="work-placeholder-title">{project.data.title}</div>
          <div class="work-placeholder-arrow">View Project <svg width="11" height="9" viewBox="0 0 12 10" fill="none"><path d="M1 5h10M6 1l5 4-5 4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg></div>
        </div>
        <div class="work-overlay">
          <div class="work-title">{project.data.title}</div>
          <div class="work-tags">
            {project.data.tags.map(tag => <span class="work-tag">{tag}</span>)}
          </div>
        </div>
      </a>
    ))}
  </div>
  <div class="works-show-more" id="showMoreWrap">
    <button class="btn-show-more" id="btnShowMore">
      Show More
      <svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
    </button>
  </div>

  <script define:vars={{totalProjects: sorted.length}}>
  const PER_PAGE = 3;
  const grid = document.getElementById('worksGrid');
  const btn = document.getElementById('btnShowMore');

  function updateShowMore() {
    const hidden = grid.querySelectorAll('.work-card.hidden');
    btn.style.display = hidden.length > 0 ? 'inline-flex' : 'none';
  }

  btn?.addEventListener('click', () => {
    const hidden = Array.from(grid.querySelectorAll('.work-card.hidden')).slice(0, PER_PAGE);
    hidden.forEach((c, i) => {
      c.classList.remove('hidden');
      setTimeout(() => c.classList.add('visible'), i * 100);
    });
    updateShowMore();
  });

  updateShowMore();
  </script>
</section>

