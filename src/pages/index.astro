  <script>
// CURSOR
const cursor=document.getElementById('cursor');
const ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function animC(){cursor.style.left=mx+'px';cursor.style.top=my+'px';rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animC)})();


// ===== HERO PARTICLE (PROPERLY RESPONSIVE) =====
(function(){
  const cv = document.getElementById('ascii-canvas');
  if (!cv) return;
  
  const ctx = cv.getContext('2d');
  let particles = [];
  let img = new Image();
  let imgLoaded = false;
  let isAssembled = false;
  let visible = true;
  
  // ===== CONFIG (UBAH DI SINI) =====
  const CFG = {
    dotSize: 1.75,              // ← Ukuran dot (1-5)
    gridSpacing: 5,          // ← Jarak dot (2=rapat, 4=normal, 8=sparse)
    brightnessThreshold: 138, // ← Brightness cutoff (20-200, LEBIH KECIL = lebih banyak dot)
    dotColor: 'rgba(201,169,110,',
    alphaScattered: 0.5,    // ← Alpha saat scattered
    alphaAssembled: 0.9,     // ← Alpha saat assembled
    assemblySpeed: 0.1,      // ← Kecepatan assembly (0.05=lambat, 0.2=cepat)
    maxParticles: 5000       // ← Max particle (1000-8000)
  };
  
  const io = new IntersectionObserver(e => {
    visible = e[0].isIntersecting;
  }, {threshold: 0});
  io.observe(cv);
  
  function resizeCanvas() {
    cv.width = window.innerWidth;
    cv.height = window.innerHeight;
    if (imgLoaded) initParticles();
  }
  
  function initParticles() {
    particles = [];
    if (!imgLoaded) return;
    
    // ===== MEMORY CANVAS (FIXED REFERENCE) =====
    const mem = document.createElement('canvas');
    mem.width = 800;
    mem.height = 450;
    const mCtx = mem.getContext('2d');
    mCtx.drawImage(img, 0, 0, mem.width, mem.height);
    let imgData = mCtx.getImageData(0, 0, mem.width, mem.height);
    
    // ===== OBJECT-FIT COVER LOGIC (RESPONSIVE) =====
    const cRatio = cv.width / cv.height;  // current canvas ratio
    let rW, rH, oX, oY;
    
    if (cRatio > 16/9) {
      // Canvas lebih lebar (landscape) → scale to width
      rW = cv.width;
      rH = cv.width / (16/9);
      oX = 0;
      oY = (cv.height - rH) / 2;
    } else {
      // Canvas lebih tinggi (portrait) → scale to height
      rW = cv.height * (16/9);
      rH = cv.height;
      oX = (cv.width - rW) / 2;
      oY = 0;
    }
    
    // ===== SPAWN PARTICLES (BRIGHTNESS-BASED) =====
    let count = 0;
    for (let y = 0; y < mem.height; y += CFG.gridSpacing) {
      for (let x = 0; x < mem.width; x += CFG.gridSpacing) {
        if (count >= CFG.maxParticles) break;
        
        let i = (y * imgData.width + x) * 4;
        let bright = (imgData.data[i] + imgData.data[i+1] + imgData.data[i+2]) / 3;
        
        // ← UBAH: gelap area (GELAP < threshold = spawn)
      if (bright < CFG.brightnessThreshold && imgData.data[i+3] > 50) {
        particles.push({
          tx: (x / mem.width) * rW + oX,
          ty: (y / mem.height) * rH + oY,
          x: Math.random() * cv.width,
          y: Math.random() * cv.height,
          vx: (Math.random() - 0.5) * 1.5,
          vy: (Math.random() - 0.5) * 1.5,
          alpha: CFG.alphaScattered
        });
        count++;
      }
      }
    }
  }
  
let mouseX = cv.width / 2;
let mouseY = cv.height / 2;

window.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

function loop() {
  if (visible) {
    ctx.clearRect(0, 0, cv.width, cv.height);
    
    particles.forEach(p => {
      // ===== MOUSE PUSH EFFECT =====
      const dx = mouseX - p.x;
      const dy = mouseY - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const pushRadius = 20;
      const pushForce = 1.5;
      
      if (dist < pushRadius && dist > 0) {
        const angle = Math.atan2(dy, dx);
        const force = ((pushRadius - dist) / pushRadius) * pushForce;
        p.vx -= Math.cos(angle) * force;
        p.vy -= Math.sin(angle) * force;
      }
      
      if (isAssembled) {
        p.x += (p.tx - p.x) * CFG.assemblySpeed;
        p.y += (p.ty - p.y) * CFG.assemblySpeed;
        p.alpha = CFG.alphaAssembled;
      } else {
        p.vx = (p.vx + (Math.random() - 0.5) * 0.12) * 0.88;
        p.vy = (p.vy + (Math.random() - 0.5) * 0.12) * 0.88;
        p.x += p.vx;
        p.y += p.vy;
        
        if (p.x < -50 || p.x > cv.width + 50) {
          p.x = p.x < 0 ? cv.width + 50 : -50;
        }
        if (p.y < -50 || p.y > cv.height + 50) {
          p.y = p.y < 0 ? cv.height + 50 : -50;
        }
        
        p.alpha = CFG.alphaScattered;
      }
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, CFG.dotSize, 0, Math.PI * 2);
      ctx.fillStyle = CFG.dotColor + Math.max(0.05, p.alpha) + ')';
      ctx.fill();
    });
  }
  
  requestAnimationFrame(loop);
}
  
  window.addEventListener('resize', resizeCanvas);
  
  cv.addEventListener('click', () => {
    isAssembled = !isAssembled;
  });
  
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    imgLoaded = true;
    resizeCanvas();
    loop();
  };
  
  img.src = 'https://raw.githubusercontent.com/irfan-wahyu/irfan.site/main/ChatGPT%20Image%20May%2030%2C%202026%2C%2002_09_04%20AM.png';
  
  resizeCanvas();
})();


// ===== PHOTO PARTICLE (ABOUT SECTION - RETRO PIXEL GRID) =====
(function(){
  const canvas=document.getElementById('particle-canvas');
  const ctx=canvas.getContext('2d');
  let particles=[],isAssembled=false,visible=true;
  let photoImg=new Image();
  let photoLoaded=false;
  let animId=null;
  
  // INTERSECTION OBSERVER — stop render saat tidak visible
  const io=new IntersectionObserver(e=>{
    visible=e[0].isIntersecting;
  },{threshold:0});
  io.observe(canvas);
  
  function resize(){
    canvas.width=canvas.offsetWidth;
    canvas.height=canvas.offsetHeight;
    if(photoLoaded)initParticles();
  }
  
  function initParticles(){
    particles=[];
    if(!photoLoaded)return;
    
    // ===== KONFIGURASI GRID - UBAH UNTUK OPTIMIZE =====
    const COLS = window.innerWidth < 768 ? 15 : 20;  // ← MOBILE: 15, DESKTOP: 25 (semakin besar = lebih banyak tile)
    const ROWS = window.innerWidth < 768 ? 8 : 12;   // ← MOBILE: 8, DESKTOP: 12
    const tileW = canvas.width / COLS;
    const tileH = canvas.height / ROWS;
    
    // ===== CROP IMAGE (JANGAN DIUBAH) =====
    const imgRatio = photoImg.width / photoImg.height;
    const canvasRatio = canvas.width / canvas.height;
    let srcW, srcH, srcX, srcY;
    
    if (canvasRatio > imgRatio) {
      srcW = photoImg.width;
      srcH = photoImg.width / canvasRatio;
      srcX = 0;
      srcY = (photoImg.height - srcH) / 2;
    } else {
      srcH = photoImg.height;
      srcW = photoImg.height * canvasRatio;
      srcX = (photoImg.width - srcW) / 2;
      srcY = 0;
    }
    
    for(let r=0; r<ROWS; r++){
      for(let c=0; c<COLS; c++){
        const sx = srcX + c * (srcW / COLS);
        const sy = srcY + r * (srcH / ROWS);
        const sw = srcW / COLS;
        const sh = srcH / ROWS;
        const tx = c * tileW;
        const ty = r * tileH;
        
        // ===== KONFIGURASI ASSEMBLY SPEED =====
        const pSpeed = 0.03 + Math.random() * 0.03;  // ← UBAH range: (0.03-0.05 lambat, 0.05-0.08 cepat)
        const pDelay = Math.floor(Math.random() * 25);  // ← UBAH: 3=cepat, 5=normal, 8=lambat (assembly delay)
        
        // ===== KONFIGURASI SCATTER DISTANCE =====
        const rx = (Math.random() - 0.5) * canvas.width * 1.5 + canvas.width / 2;  // ← UBAH: 1.2=dekat, 1.5=normal, 2.0=jauh
        const ry = (Math.random() - 0.5) * canvas.height * 1.5 + canvas.height / 2;

        particles.push({
          sx: sx, sy: sy, sw: sw, sh: sh,
          tx: tx, ty: ty,
          tw: tileW, th: tileH,
          x: rx, y: ry,
          angleX: Math.random() * Math.PI * 100,
          angleY: Math.random() * Math.PI * 100,
          floatSpeed: 0.05 + Math.random() * 0.5,  // ← UBAH: (0.03 halus, 0.1 normal, 0.15 kasar)
          moveRange: 50 + Math.random() * 30,      // ← UBAH: (30-40 minimal, 50-75 normal, 100+ ekstrim)
          speed: pSpeed,
          delay: pDelay,
          currentDelay: pDelay
        });
      }
    }
  }
  
  function draw(){
    if(visible) {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      
      particles.forEach(p=>{
        if(isAssembled){
          if (p.currentDelay > 0) {
            p.currentDelay--;
          } else {
            p.x += (p.tx - p.x) * p.speed;
            p.y += (p.ty - p.y) * p.speed;
          }
        }else{
          p.currentDelay = p.delay;
          p.angleX += p.floatSpeed;
          p.angleY += p.floatSpeed;
          p.x += Math.sin(p.angleX) * (p.moveRange * 0.05);
          p.y += Math.cos(p.angleY) * (p.moveRange * 0.05);
          
          if(p.x < -100) p.x = canvas.width + 100;
          if(p.x > canvas.width + 100) p.x = -100;
          if(p.y < -100) p.y = canvas.height + 100;
          if(p.y > canvas.height + 100) p.y = -100;
        }
        
        ctx.drawImage(photoImg, p.sx, p.sy, p.sw, p.sh, p.x, p.y, p.tw, p.th);
        
        // ===== BORDER EFFECT (OPTIONAL) =====
        if(isAssembled) {
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';  // ← UBAH: (0 none, 0.05 subtle, 0.2 visible)
          ctx.lineWidth = 0.5;
          ctx.strokeRect(p.x, p.y, p.tw, p.th);
        }
      });
      
      // ===== SCANLINE EFFECT (OPTIONAL) =====
      ctx.fillStyle = 'rgba(11, 13, 17, 0.05)';  // ← UBAH opacity: (0 none, 0.05 subtle, 0.15 strong)
      for (let i = 0; i < canvas.height; i += 4) {
        ctx.fillRect(0, i, canvas.width, 1);
      }
    }
    
    animId=requestAnimationFrame(draw);
  }
  
  const wrap=document.querySelector('.about-photo-wrap');
  wrap.addEventListener('click',()=>{isAssembled=!isAssembled;});
  
  window.addEventListener('resize',resize);
  
  photoImg.crossOrigin='anonymous';
  photoImg.onload=()=>{photoLoaded=true; initParticles();};
  photoImg.src='https://raw.githubusercontent.com/irfan-wahyu/irfan.site/main/ChatGPT%20Image%20May%2030%2C%202026%2C%2002_09_04%20AM.png';
  
  resize();draw();
})();

