---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { skills } from '../data/skills';

export const prerender = true;

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const base = import.meta.env.BASE_URL;
---
<Layout title="Irfan Wahyu — Systemic Thinker. Visual Maker.">
  <Nav variant="home" />
  <style is:global>
    /* ========================================================
       ✨ OVERRIDE CSS STRUKTUR ANIMASI BARU (HP & TEXT EFFECT)
       ======================================================== */
    
    /* 1. Paksa Judul About Center & Rapi khusus di Layar HP */
    @media (max-width: 768px) {
      .about-text .heading-anim {
        text-align: center !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        width: 100% !important;
      }
      .about-text .heading-anim .word-unit {
        justify-content: center !important;
      }
      .about-body {
        text-align: center !important;
      }
    }

    /* 2. Style Dasar Unit Teks Kalimat (Sentence) & Kata (Word) */
    .word-unit {
      display: inline-block;
      opacity: 0;
      filter: blur(8px);
      transform: translateY(10px);
      transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  filter 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    }
    
    .sentence-unit {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(12px);
      transition: opacity 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  filter 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.9s cubic-bezier(0.25, 1, 0.5, 1);
    }

    /* 3. Animasi Fade Up Santai untuk Kartu Praktek & Info */
    .about-info-card {
      opacity: 0;
      transform: translateY(25px) !important; /* Diubah dari geser kanan jadi murni naik ke atas */
      transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.8s cubic-bezier(0.25, 1, 0.5, 1) !important;
    }
    .about-info-card.visible {
      opacity: 1;
      transform: translateY(0) !important;
    }

    /* Durasi naik Areas of Practice diperlambat biar berbobot */
    .card-anim {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1.1s cubic-bezier(0.24, 1, 0.32, 1), 
                  transform 1.1s cubic-bezier(0.24, 1, 0.32, 1) !important;
    }
    .card-anim.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Animasi Node Roadmap */
    .roadmap-node {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.9s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .roadmap-node.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <button class="modal-close" id="modalClose">✕</button>
      <div class="modal-num" id="modalNum"></div>
      <div class="modal-domain" id="modalDomain"></div>
    </div>
    <div class="modal-body">
      <p class="modal-desc" id="modalDesc"></p>
      <div class="modal-section-label">Dengan</div>
      <div class="modal-tools" id="modalTools"></div>
    </div>
  </div>
</div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">I · W</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#works">Works</a></li>
    <li><a href="#philosophy">Philosophy</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero" class="has-corners">
  <span class="c-tl"></span><span class="c-tr"></span><span class="c-bl"></span><span class="c-br"></span>
  <canvas id="ascii-canvas"></canvas>
  <div class="hero-content">
    <div class="hero-eyebrow">Portfolio</div>
    <h1 class="hero-heading">Lagi Debugging Bang.<br><em>Nanti Kalo Ga Ngebug.</em></h1>
    <p class="hero-paragraph">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque vehicula sapien vel urna malesuada, ut consequat enim fringilla dignissim gravida.</p>
    <div class="hero-btn-wrap">
      <a href="#" class="hero-btn" style="pointer-events:all">
        Get in Touch
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>
</section>

<div class="section-divider"><div class="section-divider-diamond"></div></div>

<!-- ABOUT -->
<section id="about" class="has-corners">
  <span class="c-tl"></span><span class="c-tr"></span><span class="c-bl"></span><span class="c-br"></span>
  <div class="about-grid">
    <div class="about-photo-wrap">
      <canvas id="particle-canvas"></canvas>
    </div>
    <div class="about-text">
      <h2 class="heading-anim">bla bla bla<br><em>bli bli bli.</em></h2>
      <div class="about-container">
        {/* PERBAIKAN: Memakai class khusus about-text-fade agar ukurannya tetep abu-abu kecil bawaan lu */}
        <p class="about-body heading-anim about-text-fade">Curabitur luctus felis ac nunc venenatis, vitae sodales purus ultrices. Integer convallis magna nec lacus consequat, vel vestibulum nisl accumsan. Vivamus sagittis ante a felis dignissim odio fermentum euismod.</p>
      </div>
      <div class="about-info-grid">
        {/* PERBAIKAN: Efek dirubah murni dari bawah ke atas dengan staggered delay rapi (0ms -> 120ms -> 240ms -> 360ms) */}
        <div class="about-info-card" data-delay="0">
          <div class="about-info-icon">✦</div>
          <div><div class="about-info-label">Pendidikan</div><div class="about-info-value">Maunya sih Informatika<br>UNYEAH</div></div>
        </div>
        <div class="about-info-card" data-delay="120">
          <div class="about-info-icon">◈</div>
          <div><div class="about-info-label">Keahlian</div><div class="about-info-value">Lorem Ipsum, Ipsum Lorem,<br>Dolor sit</div></div>
        </div>
        <div class="about-info-card" data-delay="240">
          <div class="about-info-icon">◉</div>
          <div><div class="about-info-label">Minat</div><div class="about-info-value">Amet Amet,Cogito,<br>Ergo Sum</div></div>
        </div>
        <div class="about-info-card" data-delay="360">
          <div class="about-info-icon">⟡</div>
          <div><div class="about-info-label">Berbasis di</div><div class="about-info-value">Watasi,Wakatta<br>Wakaranai</div></div>
        </div>
      </div>
    </div>
  </div>

  <div class="deco-line fade-in"><div class="deco-line-mark">◆</div></div>
  <p class="skill-heading fade-in">Areas of Practice</p>

  <div class="skill-grid">
    {skills.map((skill) => (
      <div 
        class="skill-card clickable card-anim" 
        data-delay={skill.delay}
        data-num={skill.num}
        data-domain={skill.domain}
        data-desc={skill.desc}
        data-tools={skill.tools.join(',')}
      >
        <span class="skill-card-num">{skill.num}</span>
        <span class="skill-card-arrow">↗</span>
        <div class="skill-card-domain">{skill.domain}</div>
        <div class="skill-card-essence">{skill.essence}</div>
      </div>
    ))}
  </div>
</section>

<div class="section-divider"><div class="section-divider-diamond"></div></div>

<!-- WORKS -->
<section id="works" class="has-corners">
