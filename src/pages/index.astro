---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { skills } from '../data/skills';
import { GraduationCap, Bookmark, University, User } from '@lucide/astro';

export const prerender = true;

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const base = import.meta.env.BASE_URL;
---
<Layout title="Irfan Wahyu — Systemic Thinker. Visual Maker.">
  <Nav variant="home" />

  <style is:global>
    @media (max-width: 768px) {
      .about-text .heading-anim {
        text-align: center !important;
        display: block !important; 
        width: 100% !important;
      }
      .about-text .heading-anim .word-unit {
        display: inline !important;
        white-space: normal !important;
        letter-spacing: normal !important;
      }
      .about-body {
        text-align: center !important;
      }
    }

    .about-container p.about-body.heading-anim.about-text-fade {
      width: 100% !important;
      max-width: 100% !important;
      display: block !important;
    }

    .about-container .sentence-unit,
    .about-container p.about-body .sentence-unit {
      width: 100% !important;
      max-width: 100% !important;
      display: block !important;
      text-align: justify !important; 
      text-align-last: left !important; 
    }

    @media (max-width: 768px) {
      .about-container .sentence-unit,
      .about-container p.about-body .sentence-unit {
        text-align: center !important;
        text-align-last: center !important;
      }
    }

    .word-unit {
      display: inline-block;
      opacity: 0;
      filter: blur(8px);
      transform: translateY(10px);
      transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  filter 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    }
    
    .sentence-unit {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(12px);
      transition: opacity 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  filter 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.9s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .about-info-card {
      opacity: 0;
      transform: translateY(25px) !important; 
      transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.8s cubic-bezier(0.25, 1, 0.5, 1) !important;
    }

    .about-info-card.visible {
      opacity: 1;
      transform: translateY(0) !important;
    }

    .card-anim {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1.1s cubic-bezier(0.24, 1, 0.32, 1), 
                  transform 1.1s cubic-bezier(0.24, 1, 0.32, 1) !important;
    }

    .card-anim.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .roadmap-node {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.9s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.9s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .roadmap-node.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  {/* --- MODAL DIALOG ARCHIVE --- */}
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <div class="modal-header">
        <button class="modal-close" id="modalClose">✕</button>
        <div class="modal-num" id="modalNum"></div>
        <div class="modal-domain" id="modalDomain"></div>
      </div>
      <div class="modal-body">
        <p class="modal-desc" id="modalDesc"></p>
        <div class="modal-section-label">Dengan</div>
        <div class="modal-tools" id="modalTools"></div>
      </div>
    </div>
  </div>

  {/* --- BRAND NAVIGATION --- */}
  <nav>
    <a href="#" class="nav-logo">I · W</a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#works">Works</a></li>
      <li><a href="#philosophy">Philosophy</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  {/* --- SECTION: HERO DISPLAY --- */}
  <section id="hero" class="has-corners">
    <span class="c-tl"></span><span class="c-tr"></span><span class="c-bl"></span><span class="c-br"></span>
    <canvas id="ascii-canvas"></canvas>
    
    <div class="hero-content">
      <div class="hero-eyebrow">Personal Website</div>
      <h1 class="hero-heading">Thinking in systems<br><em>Building in layers</em></h1>
      <p class="hero-paragraph">Still learning how to think & build. Ed-tech student by day, visual thinker by habit. exploring the overlap between systems, design, and digital craft. This space is part archive & part experiment.</p>
      
      <div class="hero-btn-wrap hero-btn-animate-intro" style="display: flex; gap: 16px; align-items: center; justify-content: center; width: 100%;">
        <a href="https://avely.me/irfan-wahyu" class="hero-btn primary-bounce-btn" style="pointer-events:all">
          Get in Touch
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>

        <a href="/work" class="hero-btn secondary-stroke-btn" style="pointer-events:all">
          See My Work
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>
    </div>
<style>
      .hero-btn-wrap {
        margin-top: 32px;
      }

      .hero-btn-animate-intro {
        opacity: 0;
        filter: blur(10px);
        transform: translateY(15px);
        animation: heroBtnIntro 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) 2s forwards;
      }

      @keyframes heroBtnIntro {
        to {
          opacity: 1;
          filter: blur(0);
          transform: translateY(0);
        }
      }

      .primary-bounce-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
      }
      
      .primary-bounce-btn svg {
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
      }

      .primary-bounce-btn:hover {
        transform: scale(1.05) !important;
      }

      .primary-bounce-btn:hover svg {
        transform: translateX(4px) !important;
      }

      .secondary-stroke-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        position: relative;
        overflow: hidden;
        z-index: 1;
        background: transparent !important;
        border: 1px solid #d4b373 !important;
        color: #d4b373 !important;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease !important;
      }

      .secondary-stroke-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: 130%;
        width: 130%;
        height: 100%;
        background: linear-gradient(to left, #d4b373, #f5e6ca, transparent) !important;
        opacity: 0.35;
        z-index: -1;
        transition: left 0.6s cubic-bezier(0.25, 1, 0.5, 1);
      }

      .secondary-stroke-btn svg {
        stroke: #d4b373 !important;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
      }

      .secondary-stroke-btn:hover {
        transform: scale(1.05) !important;
        border-color: #f5e6ca !important;
      }

      .secondary-stroke-btn:hover::before {
        left: -30%;
      }

      .secondary-stroke-btn:hover svg {
        transform: translateX(4px) !important;
      }

      @media (max-width: 480px) {
        .hero-btn-wrap {
          gap: 10px !important;
          padding: 0 16px;
        }

        .primary-bounce-btn,
        .secondary-stroke-btn {
          padding: 10px 16px !important;
          font-size: 0.52rem !important;
          letter-spacing: 0.12em !important;
          flex: 1;
          justify-content: center;
          white-space: nowrap !important;
          height: 38px !important;
        }

        .primary-bounce-btn svg,
        .secondary-stroke-btn svg {
          width: 10px !important;
          height: 10px !important;
        }
      }
    </style>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  {/* --- SECTION: ABOUT ME --- */}
  <section id="about" class="has-corners">
    <span class="c-tl"></span><span class="c-tr"></span><span class="c-bl"></span><span class="c-br"></span>
    <div class="about-grid">
      <div class="about-photo-wrap">
        <canvas id="particle-canvas"></canvas>
      </div>
      <div class="about-text">
        <h2 class="heading-anim">You're here<br><em>I'm Irfan Wahyu</em></h2>
        <div class="about-container">
          <p class="about-body heading-anim about-text-fade">Currently finding ground in Yogyakarta. Still learning & still exploring across systems technology and the visual world. That curiosity led me to Educational Technology at UNY, a field sitting at the intersection of Philosophical Science, Digital Technology and Education.It's not the most obvious path but i think it's the one that felt most honest i choice. I'm still figuring out who I am and what I'm building toward, this space reflects that process Some things here are finished Most are still forming.</p>
        </div>
        
        <div class="about-info-grid">
          <div class="about-info-card" data-delay="0">
            <div class="about-info-icon"><GraduationCap size={18} /></div>
            <div><div class="about-info-label">Pendidikan</div><div class="about-info-value">Teknologi Pendidikan<br>Universitas Negeri Yogyakarta</div></div>
          </div>
          <div class="about-info-card" data-delay="120">
            <div class="about-info-icon"><Bookmark size={18} /></div>
            <div><div class="about-info-label">Minat</div><div class="about-info-value">Membaca, Digital Tech, Sistem</div></div>
          </div>
          <div class="about-info-card" data-delay="240">
            <div class="about-info-icon"><University size={18} /></div>
            <div><div class="about-info-label">Status</div><div class="about-info-value">First Year<br>2026</div></div>
          </div>
          <div class="about-info-card" data-delay="360">
            <div class="about-info-icon"><User size={18} /></div>
            <div><div class="about-info-label">Persona</div><div class="about-info-value">INTJ-T(Turbulent Architect)</div></div>
          </div>
        </div>
      </div>
    </div>

    <div class="deco-line fade-in"><div class="deco-line-mark">◆</div></div>
    <p class="skill-heading fade-in">Areas of Practice</p>

    <div class="skill-grid">
      {skills.map((skill) => (
        <div 
          class="skill-card clickable card-anim" 
          data-delay={skill.delay}
          data-num={skill.num}
          data-domain={skill.domain}
          data-desc={skill.desc}
          data-tools={skill.tools.join(',')}
        >
          <span class="skill-card-num">{skill.num}</span>
          <span class="skill-card-arrow">↗</span>
          <div class="skill-card-domain">{skill.domain}</div>
          <div class="skill-card-essence">{skill.essence}</div>
        </div>
      ))}
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  {/* --- SECTION: WORKS GALLERY --- */}
  <section id="works" class="has-corners">
    <div class="works-header fade-in">
      <h2 class="works-title heading-anim">Selected <em>Works</em></h2>
      <a href={`${base}works`} class="works-all">
        All Projects 
        <svg width="13" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M1 5h12M8 1l5 4-5 4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        </svg>
      </a>
    </div>

    <div class="works-grid" id="worksGrid">
      {sorted.map((project, idx) => (
        <a 
          href={`${base}works/${project.id}/`} 
          class={`work-card work-anim${idx >= 3 ? ' hidden' : ''}`} 
          data-delay={idx >= 3 ? '0' : String(idx * 100)} 
          style="position: relative; overflow: hidden; display: block;"
        >
          {project.data.thumbnail && (
            <img 
              src={project.data.thumbnail.startsWith('http') || project.data.thumbnail.startsWith('/') 
                ? project.data.thumbnail 
                : `${base}images/${project.data.thumbnail}`} 
              alt={project.data.title} 
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;" 
            />
          )}

          <div class="work-card-dimmer" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(11, 13, 17, 0.4); z-index: 2; pointer-events: none; transition: opacity 0.3s ease;"></div>

          <div class="work-initial-center-content" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; z-index: 3; pointer-events: none; transition: transform 0.4s ease, opacity 0.4s ease;">
            <div class="work-title">{project.data.title}</div>
          </div>

          <div 
            class="work-overlay" 
            style="z-index: 5 !important; position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; padding: 1.5rem !important; display: flex !important; flex-direction: row !important; justify-content: space-between !important; align-items: flex-end !important; box-sizing: border-box !important;"
          >
            <div style="display: flex !important; flex-direction: column !important; gap: 6px !important; align-items: flex-start !important; max-width: 60% !important; text-align: left !important; margin: 0 !important;">
              <div class="work-title" style="margin: 0 !important;">{project.data.title}</div>
              {project.data.subtitle && (
                <div 
                  class="work-title" 
                  style="font-size: 0.9rem !important; font-weight: normal !important; font-style: normal !important; opacity: 0.8; margin: 0 !important; text-transform: none !important; letter-spacing: normal !important;"
                >
                  {project.data.subtitle.split(' ').length > 6 
                    ? project.data.subtitle.split(' ').slice(0, 6).join(' ') + '...' 
                    : project.data.subtitle}
                </div>
              )}
              <div class="work-tags" style="margin-top: 4px !important; display: flex !important; flex-wrap: wrap !important; gap: 5px !important;">
                {project.data.tags?.map(tag => (
                  <span class="work-tag">{tag}</span>
                ))}
              </div>
              {project.data.description && (
                <p style="color: #ffffff; font-size: 0.8rem; opacity: 0.7; margin-top: 6px !important; margin-bottom: 0 !important; max-width: 100% !important;">
                  {project.data.description.split(' ').length > 12 
                    ? project.data.description.split(' ').slice(0, 12).join(' ') + '...' 
                    : project.data.description}
                </p>
              )}
            </div>

            <div class="work-tags" style="margin: 0 !important; display: flex !important; align-items: center !important;">
              <div class="work-tag" style="display: flex !important; align-items: center !important; gap: 0.5rem !important; margin: 0 !important;">
                View Project
                <svg width="11" height="9" viewBox="0 0 12 10" fill="none" style="display: inline-block; vertical-align: middle;">
                  <path d="M1 5h10M6 1l5 4-5 4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="works-show-more" id="showMoreWrap">
      <button class="btn-show-more" id="btnShowMore">
        Show More
        <svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
      </button>
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  {/* --- SECTION: PHILOSOPHY & ROADMAP --- */}
  <section id="philosophy" class="has-corners corner-bottom">
    <div class="slider-wrap">
      <div class="slide active" id="slide-1">
        <div class="slide-section-label">Philosophy</div>
        <div class="slide-1-content" style="width: 100% !important; max-width: 100% !important; padding: 0 !important;">
          <div class="slide-quote heading-anim slide-quote" style="text-align: center !important; margin-bottom: 0px !important; padding-bottom: 0px !important;">
            "Die jugendliche Seele blicke auf das Leben zurück mit der Frage: was hast du bisher wirklich geliebt, was hat deine Seele gezogen was hat sie beherrscht und gleichzeitig beglückt? Stelle diese Reihe verehrter Gegenstände vor dir auf, und vielleicht zeigen sie dir ein Grundgesetz du deines eigentlichen Selbst: werde der du bist!"
          </div>
          
          <div class="slide-quote heading-anim slide-quote" style="text-align: center !important; margin-top: 1.5rem !important; padding-top: 0px !important;">
            <span style="content: none !important; display: block !important; width: 100% !important; text-align: center !important;">
              — Friedrich Nietzsche
            </span>
            <style>
              #slide-1 .slide-quote:nth-child(2)::before,
              #slide-1 .slide-quote:nth-child(2)::after {
                content: none !important;
              }
            </style>
          </div>
          
          <div class="slide-deco"><div class="slide-deco-mark">✦</div></div>
          
          <p class="slide-body heading-anim about-text-fade" style="width: 100% !important; max-width: 700px !important; margin-left: auto !important; margin-right: auto !important; padding: 0 !important; text-align: center !important; line-height: 1.7;">
            For me, this archive is a deliberate space to gather the things I focus on. Combining the logic of computing systems and the expression of visual forms is my independent way to deconstruct how structures work. In a world full of pre-made directions and exploring these layers honestly is my personal process to build a solid foundation and slowly become who I am.
          </p>
        </div>
      </div>

      <div class="slide" id="slide-2">
        <div class="slide-section-label">Roadmap</div>
        <h3 class="roadmap-title heading-anim">Where I'm Heading</h3>
        
        <div class="roadmap">
          <div class="roadmap-node" data-delay="0">
            <div class="roadmap-dot active-dot"></div>
            <div class="roadmap-phase">Phase 01 — First Year</div>
            <div class="roadmap-label">Foundation</div>
            <div class="roadmap-desc">Establishing the core academic pillars while aligning personal digital interests and creative baselines.</div>
          </div>
          
          <div class="roadmap-node" data-delay="150">
            <div class="roadmap-dot"></div>
            <div class="roadmap-phase">Phase 02 — Soon</div>
            <div class="roadmap-label">Exploration</div>
            <div class="roadmap-desc">Expanding into independent system environments, exploring command logic, and testing visual boundaries.</div>
          </div>
          
          <div class="roadmap-node" data-delay="300">
            <div class="roadmap-dot"></div>
            <div class="roadmap-phase">Phase 03 — Soon</div>
            <div class="roadmap-label">Synthesis</div>
            <div class="roadmap-desc">Synthesizing technical logic and design principles to construct structured, interactive digital spaces.</div>
          </div>
          
          <div class="roadmap-node" data-delay="450">
            <div class="roadmap-dot"></div>
            <div class="roadmap-phase">Phase 04 — Soon</div>
            <div class="roadmap-label">Impact</div>
            <div class="roadmap-desc">Utilizing accumulated knowledge and digital mediums to empower others, helping them navigate clarity, gain understanding, and discover their own purpose in life.</div>
          </div>
        </div>
      </div>

      <div class="slider-controls">
        <div class="slider-dot active" data-slide="0"></div>
        <div class="slider-dot" data-slide="1"></div>
      </div>
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  {/* --- SECTION: FAQ ACCORDION --- */}
  <section id="faq-section" class="has-corners corner-bottom">
    <div class="faq-inner">
      <div class="slide-section-label fade-in" style="margin-bottom:var(--space-lg)">Questions</div>
      <h2 class="faq-title heading-anim">Frequently Asked<br><em>Questions.</em></h2>
      <p class="faq-subtitle heading-anim about-text-fade"></p>
      
      <div class="faq-list">
        <div class="faq-item fade-in">
          <button class="faq-question">Apa yang bisa ditemukan di website ini?<span class="faq-arrow"><svg width="13" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span></button>
          <div class="faq-answer"><p>Website ini berisi kumpulan proyek, dokumentasi pembelajaran, serta berbagai eksplorasi yang berkaitan dengan teknologi, media digital, dan hal-hal yang sedang dipelajari. Selain menjadi tempat menyimpan hasil karya, website ini juga berfungsi sebagai ruang untuk mencatat proses perkembangan dan perjalanan belajar yang terus berlangsung.</p></div>
        </div>
        
        <div class="faq-item fade-in">
          <button class="faq-question">Kenapa memilih Teknologi Pendidikan?<span class="faq-arrow"><svg width="13" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span></button>
          <div class="faq-answer"><p>Ketertarikan pada hubungan antara teknologi, media, dan proses belajar menjadi alasan utama memilih bidang ini. Teknologi Pendidikan memberikan ruang untuk mempelajari bagaimana informasi dapat disampaikan dengan lebih efektif, sekaligus memahami bagaimana teknologi dapat dimanfaatkan untuk membantu proses pembelajaran.</p></div>
        </div>
        
        <div class="faq-item fade-in">
          <button class="faq-question">Apakah semua proyek yang ditampilkan sudah selesai?<span class="faq-arrow"><svg width="13" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span></button>
          <div class="faq-answer"><p>Tidak semuanya. Beberapa proyek telah selesai dikembangkan, sementara sebagian lainnya masih berada dalam tahap eksplorasi, pengembangan, atau penyempurnaan. Website ini tidak hanya menampilkan hasil akhir, tetapi juga menjadi tempat untuk mendokumentasikan proses yang sedang berjalan.</p></div>
        </div>
        
        <div class="faq-item fade-in">
          <button class="faq-question">Bidang apa yang paling sering dieksplorasi?<span class="faq-arrow"><svg width="13" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span></button>
          <div class="faq-answer"><p>Sebagian besar eksplorasi berada di sekitar teknologi digital, media pembelajaran, desain visual, dan berbagai topik yang berkaitan dengan pengembangan media. Ketertarikan tersebut sering kali bertemu pada satu titik yang sama, yaitu bagaimana teknologi dapat digunakan untuk menyampaikan informasi dengan lebih baik.</p></div>
        </div>
        
        <div class="faq-item fade-in">
          <button class="faq-question">Apa output dari memilih jurusan ini?<span class="faq-arrow"><svg width="13" height="8" viewBox="0 0 14 8" fill="none"><path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span></button>
          <div class="faq-answer"><p>Pilihan terhadap Teknologi Pendidikan berangkat dari visi untuk memahami hubungan antara manusia, teknologi, dan proses belajar. Dalam jangka panjang, bidang ini diharapkan dapat menjadi fondasi untuk menciptakan sesuatu yang memiliki nilai dan manfaat nyata, baik dalam bentuk media, sistem, maupun solusi yang dapat membantu orang lain memperoleh akses terhadap informasi dan pembelajaran dengan lebih baik.</p></div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-diamond"></div></div>

  {/* --- SECTION: CONNECT / CONTACT --- */}
  <section id="contact" class="has-corners corner-bottom">
    <div class="contact-ring-1"></div><div class="contact-ring-2"></div>
    <div class="contact-eyebrow fade-in">Let's Connect</div>
    <h2 class="contact-heading heading-anim">Get In<br><em>Touch</em></h2>
    <p class="contact-para heading-anim about-text-fade">
      Connecting points across various networks. Find the relevant profiles and digital platforms listed through the link below.
    </p>
    
    <div class="contact-deco fade-in"><div class="contact-deco-line"></div><div class="contact-deco-mark">◆</div><div class="contact-deco-line"></div></div>
    
    <a href="https://avely.me/irfan-wahyu" target="_blank" class="contact-btn fade-in custom-bounce-btn">
      Open Links 
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </a>
  </section>

  <style>
    .custom-bounce-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.3s ease !important;
    }

    .custom-bounce-btn svg {
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }

    .custom-bounce-btn:hover {
      transform: scale(1.06);
    }

    .custom-bounce-btn:hover svg {
      transform: translateX(5px);
    }
  </style>

  {/* --- CORE ENGINE INTERACTION SCRIPT --- */}
  <script>
    // ===== CORE: MOUSE CURSOR =====
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;
    if (cursor && ring) {
      document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY });
      (function animC() {
        cursor.style.left = mx + 'px';
        cursor.style.top = my + 'px';
        rx += (mx - rx) * .1;
        ry += (my - ry) * .1;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(animC);
      })();
    }

    // ===== INTERACTIVE ENGINE: HERO BACKGROUND (ASCII) =====
    (function() {
      const cv = document.getElementById('ascii-canvas');
      if (!cv) return;
      const ctx = (cv as HTMLCanvasElement).getContext('2d');
      let particles = [];
      let img = new Image();
      let imgLoaded = false;
      let isAssembled = false;
      let visible = true;
      
      const CFG = {
        dotSize: 1.75,
        gridSpacing: 5,
        brightnessThreshold: 138,
        dotColor: 'rgba(201,169,110,',
        alphaScattered: 0.5,
        alphaAssembled: 0.9,
        assemblySpeed: 0.1,
        maxParticles: 5000
      };
      
      const io = new IntersectionObserver(e => { visible = e[0].isIntersecting; }, { threshold: 0 });
      io.observe(cv);
      
      function resizeCanvas() {
        (cv as HTMLCanvasElement).width = window.innerWidth;
        (cv as HTMLCanvasElement).height = window.innerHeight;
        if (imgLoaded) initParticles();
      }
      
      function initParticles() {
        particles = [];
        if (!imgLoaded) return;
        const mem = document.createElement('canvas');
        mem.width = 800; mem.height = 450;
        const mCtx = mem.getContext('2d');
        mCtx.drawImage(img, 0, 0, mem.width, mem.height);
        let imgData = mCtx.getImageData(0, 0, mem.width, mem.height);
        const cRatio = (cv as HTMLCanvasElement).width / (cv as HTMLCanvasElement).height;
        let rW, rH, oX, oY;
        if (cRatio > 16/9) {
          rW = (cv as HTMLCanvasElement).width; rH = (cv as HTMLCanvasElement).width / (16/9); oX = 0; oY = ((cv as HTMLCanvasElement).height - rH) / 2;
        } else {
          rW = (cv as HTMLCanvasElement).height * (16/9); rH = (cv as HTMLCanvasElement).height; oX = ((cv as HTMLCanvasElement).width - rW) / 2; oY = 0;
        }
        let count = 0;
        for (let y = 0; y < mem.height; y += CFG.gridSpacing) {
          for (let x = 0; x < mem.width; x += CFG.gridSpacing) {
            if (count >= CFG.maxParticles) break;
            let i = (y * imgData.width + x) * 4;
            let bright = (imgData.data[i] + imgData.data[i+1] + imgData.data[i+2]) / 3;
            if (bright < CFG.brightnessThreshold && imgData.data[i+3] > 50) {
              particles.push({
                tx: (x / mem.width) * rW + oX, ty: (y / mem.height) * rH + oY,
                x: Math.random() * (cv as HTMLCanvasElement).width, y: Math.random() * (cv as HTMLCanvasElement).height,
                vx: (Math.random() - 0.5) * 1.5, vy: (Math.random() - 0.5) * 1.5, alpha: CFG.alphaScattered
              });
              count++;
            }
          }
        }
      }
      
      let mouseX = window.innerWidth / 2; let mouseY = window.innerHeight / 2;
      window.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });

      function loop() {
        if (visible && ctx) {
          ctx.clearRect(0, 0, (cv as HTMLCanvasElement).width, (cv as HTMLCanvasElement).height);
          particles.forEach(p => {
            const dx = mouseX - p.x; const dy = mouseY - p.y; const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 20 && dist > 0) {
              const angle = Math.atan2(dy, dx); p.vx -= Math.cos(angle) * 1.5; p.vy -= Math.sin(angle) * 1.5;
            }
            if (isAssembled) {
              p.x += (p.tx - p.x) * CFG.assemblySpeed; p.y += (p.ty - p.y) * CFG.assemblySpeed; p.alpha = CFG.alphaAssembled;
            } else {
              p.vx = (p.vx + (Math.random() - 0.5) * 0.12) * 0.88; p.vy = (p.vy + (Math.random() - 0.5) * 0.12) * 0.88; p.x += p.vx; p.y += p.vy;
              if (p.x < -50 || p.x > (cv as HTMLCanvasElement).width + 50) p.x = p.x < 0 ? (cv as HTMLCanvasElement).width + 50 : -50;
              if (p.y < -50 || p.y > (cv as HTMLCanvasElement).height + 50) p.y = p.y < 0 ? (cv as HTMLCanvasElement).height + 50 : -50;
              p.alpha = CFG.alphaScattered;
            }
            ctx.beginPath(); ctx.arc(p.x, p.y, CFG.dotSize, 0, Math.PI * 2); ctx.fillStyle = CFG.dotColor + Math.max(0.05, p.alpha) + ')'; ctx.fill();
          });
        }
        requestAnimationFrame(loop);
      }
      window.addEventListener('resize', resizeCanvas);
      cv.addEventListener('click', () => { isAssembled = !isAssembled; });
      img.crossOrigin = 'anonymous';
      img.onload = () => { imgLoaded = true; resizeCanvas(); loop(); };
      img.src = 'https://raw.githubusercontent.com/irfan-wahyu/irfan.site/main/ChatGPT%20Image%20May%2030%2C%202026%2C%2002_09_04%20AM.png';
      resizeCanvas();
    })();

    // ===== INTERACTIVE ENGINE: PHOTO CANVAS PARTICLE =====
    (function() {
      const canvas = document.getElementById('particle-canvas');
      if (!canvas) return;
      const ctx = (canvas as HTMLCanvasElement).getContext('2d');
      let particles = [], isAssembled = false, visible = true;
      let photoImg = new Image();
      let photoLoaded = false;
      
      const io = new IntersectionObserver(e => { visible = e[0].isIntersecting; }, { threshold: 0 });
      io.observe(canvas);
      
      function resize() {
        (canvas as HTMLCanvasElement).width = (canvas as HTMLCanvasElement).offsetWidth;
        (canvas as HTMLCanvasElement).height = (canvas as HTMLCanvasElement).offsetHeight;
        if (photoLoaded) initParticles();
      }
      
      function initParticles() {
        particles = [];
        if (!photoLoaded) return;
        const COLS = window.innerWidth < 768 ? 15 : 20; const ROWS = window.innerWidth < 768 ? 8 : 12;
        const tileW = (canvas as HTMLCanvasElement).width / COLS; const tileH = (canvas as HTMLCanvasElement).height / ROWS;
        const imgRatio = photoImg.width / photoImg.height; const canvasRatio = (canvas as HTMLCanvasElement).width / (canvas as HTMLCanvasElement).height;
        let srcW, srcH, srcX, srcY;
        if (canvasRatio > imgRatio) {
          srcW = photoImg.width; srcH = photoImg.width / canvasRatio; srcX = 0; srcY = (photoImg.height - srcH) / 2;
        } else {
          srcH = photoImg.height; srcW = photoImg.height * canvasRatio; srcX = (photoImg.width - srcW) / 2; srcY = 0;
        }
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < COLS; c++) {
            const sx = srcX + c * (srcW / COLS); const sy = srcY + r * (srcH / ROWS);
            const sw = srcW / COLS; const sh = srcH / ROWS;
            const tx = c * tileW; const ty = r * tileH;
            particles.push({
              sx: sx, sy: sy, sw: sw, sh: sh, tx: tx, ty: ty, tw: tileW, th: tileH,
              x: (Math.random() - 0.5) * (canvas as HTMLCanvasElement).width * 1.5 + (canvas as HTMLCanvasElement).width / 2,
              y: (Math.random() - 0.5) * (canvas as HTMLCanvasElement).height * 1.5 + (canvas as HTMLCanvasElement).height / 2,
              angleX: Math.random() * Math.PI * 100, angleY: Math.random() * Math.PI * 100,
              floatSpeed: 0.05 + Math.random() * 0.5, moveRange: 50 + Math.random() * 30,
              speed: 0.03 + Math.random() * 0.03, delay: Math.floor(Math.random() * 25), currentDelay: Math.floor(Math.random() * 25)
            });
          }
        }
      }
      
      function draw() {
        if (visible && ctx) {
          ctx.clearRect(0, 0, (canvas as HTMLCanvasElement).width, (canvas as HTMLCanvasElement).height);
          particles.forEach(p => {
            if (isAssembled) {
              if (p.currentDelay > 0) p.currentDelay--;
              else { p.x += (p.tx - p.x) * p.speed; p.y += (p.ty - p.y) * p.speed; }
            } else {
              p.currentDelay = p.delay; p.angleX += p.floatSpeed; p.angleY += p.floatSpeed;
              p.x += Math.sin(p.angleX) * (p.moveRange * 0.05); p.y += Math.cos(p.angleY) * (p.moveRange * 0.05);
              if (p.x < -100) p.x = (canvas as HTMLCanvasElement).width + 100;
              if (p.x > (canvas as HTMLCanvasElement).width + 100) p.x = -100;
              if (p.y < -100) p.y = (canvas as HTMLCanvasElement).height + 100;
              if (p.y > (canvas as HTMLCanvasElement).height + 100) p.y = -100;
            }
            ctx.drawImage(photoImg, p.sx, p.sy, p.sw, p.sh, p.x, p.y, p.tw, p.th);
            if (isAssembled) {
              ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)'; ctx.lineWidth = 0.5; ctx.strokeRect(p.x, p.y, p.tw, p.th);
            }
          });
          ctx.fillStyle = 'rgba(11, 13, 17, 0.05)';
          for (let i = 0; i < (canvas as HTMLCanvasElement).height; i += 4) ctx.fillRect(0, i, (canvas as HTMLCanvasElement).width, 1);
        }
        requestAnimationFrame(draw);
      }
      const wrap = document.querySelector('.about-photo-wrap');
      wrap?.addEventListener('click', () => { isAssembled = !isAssembled; });
      window.addEventListener('resize', resize);
      photoImg.crossOrigin = 'anonymous'; photoImg.onload = () => { photoLoaded = true; initParticles(); };
      photoImg.src = 'https://raw.githubusercontent.com/irfan-wahyu/irfan.site/main/ChatGPT%20Image%20May%2030%2C%202026%2C%2002_09_04%20AM.png';
      resize(); draw();
    })();

    // ===== UI COMPONENT: SKILL DETAILS MODAL =====
    const overlay = document.getElementById('modalOverlay');
    document.getElementById('modalClose')?.addEventListener('click', () => overlay?.classList.remove('open'));
    overlay?.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('open') });
    document.querySelectorAll('.skill-card').forEach(card => {
      card.addEventListener('click', () => {
        const c = card as HTMLElement;
        document.getElementById('modalNum')!.textContent = 'Domain ' + c.dataset.num;
        document.getElementById('modalDomain')!.textContent = c.dataset.domain || '';
        document.getElementById('modalDesc')!.textContent = c.dataset.desc || '';
        const toolsEl = document.getElementById('modalTools')!; toolsEl.innerHTML = '';
        const icons = ['◈', '✦', '◉', '⟡', '▪', '◆'];
        c.dataset.tools?.split(',').forEach((t, i) => {
          const s = document.createElement('span'); s.className = 'modal-tool';
          s.innerHTML = `<span class="modal-tool-icon">${icons[i % icons.length]}</span>${t.trim()}`;
          toolsEl.appendChild(s);
        });
        overlay?.classList.add('open');
      });
    });

    // ===== UI COMPONENT: GALLERY LOAD MORE =====
    (function() {
      const grid = document.getElementById('worksGrid');
      const btn = document.getElementById('btnShowMore');
      const wrap = document.getElementById('showMoreWrap');
      const PER_PAGE = 3;
      btn?.addEventListener('click', () => {
        if (!grid || !wrap) return;
        const hidden = grid.querySelectorAll('.work-card.hidden');
        let revealed = 0;
        hidden.forEach(c => { if (revealed < PER_PAGE) { c.classList.remove('hidden'); revealed++ } });
        if (grid.querySelectorAll('.work-card.hidden').length === 0) wrap.style.display = 'none';
      });
    })();

    // ===== UI COMPONENT: PHILOSOPHY SLIDER =====
    (function() {
      const slides = document.querySelectorAll('.slide');
      const dots = document.querySelectorAll('.slider-dot');
      let current = 0, timer: any;
      function go(n: number) {
        slides[current].classList.remove('active'); dots[current].classList.remove('active');
        current = n; slides[current].classList.add('active'); dots[current].classList.add('active');
      }
      function startAuto() { timer = setInterval(() => go((current + 1) % slides.length), 20000) }
      function stopAuto() { clearInterval(timer) }
      dots.forEach((d, i) => { d.addEventListener('click', () => { stopAuto(); go(i); startAuto() }) });
      startAuto();
    })();

    // ===== UI COMPONENT: FAQ ACCORDION =====
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        if (!item) return;
        const wasOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item.classList.add('open');
      });
    });

    // ===== PERFORMANCE: ENGINE TYPING EFFECT =====
    (function() {
      const el = document.querySelector('.hero-heading');
      if (!el) return;
      const full1 = 'Thinking in systems'; const full2 = 'Building in layers';
      el.innerHTML = '';
      const line1 = document.createElement('span'); const br = document.createElement('br'); const em = document.createElement('em'); const cur = document.createElement('span');
      cur.className = 'typing-cursor'; el.appendChild(line1); el.appendChild(br); el.appendChild(em); el.appendChild(cur);
      let i = 0, phase = 0; const speed = 48;
      function type() {
        if (phase === 0) {
          if (i <= full1.length) { line1.textContent = full1.slice(0, i); i++; setTimeout(type, speed) }
          else { i = 0; phase = 1; setTimeout(type, 280) }
        } else {
          if (i <= full2.length) { em.textContent = full2.slice(0, i); i++; setTimeout(type, speed) }
          else { setTimeout(() => { cur.style.opacity = '0'; cur.style.transition = 'opacity .5s' }, 400) }
        }
      }
      setTimeout(type, 800);
    })();

    // ===== PARSER: TEXT PACKAGING WRAPPERS =====
    function wrapSentences(el: any, lineDelay: number) {
      const raw = el.textContent.trim();
      const chunks = raw.match(/[^,\.]+[,\.]?\s*/g) || [raw];
      const groups: any = [];
      for (let i = 0; i < chunks.length; i += 2) {
        const g = chunks.slice(i, i+2).join('').trim();
        if (g) groups.push(g);
      }
      let html = '';
      groups.forEach((g: any, i: number) => {
        html += `<span class="sentence-unit" style="display:block; transition-delay: ${i * lineDelay}ms;">${g}</span>`;
      });
      el.innerHTML = html;
    }

    function wrapHeadingWords(el: any, wordDelay: number) {
      function walk(node: any) {
        if (node.nodeType === 3) {
          const words = node.textContent.split(/(\s+)/);
          if (words.length <= 1 && !words[0].trim()) return;
          const frag = document.createDocumentFragment();
          words.forEach((w: any) => {
            if (!w.trim()) { frag.appendChild(document.createTextNode(w)); } 
            else {
              const s = document.createElement('span'); s.className = 'word-unit'; s.textContent = w; frag.appendChild(s);
            }
          });
          node.parentNode.replaceChild(frag, node);
        } else if (node.nodeType === 1 && node.nodeName !== 'SCRIPT' && node.nodeName !== 'STYLE') {
          Array.from(node.childNodes).forEach(walk);
        }
      }
      walk(el);
      el.querySelectorAll('.word-unit').forEach((w: any, i: number) => {
        w.style.transitionDelay = (i * wordDelay) + 'ms';
      });
    }

    // ===== INTERSECTION ENGINE: SCROLL OBSERVER =====
    (function() {
      document.querySelectorAll('.heading-anim').forEach(el => {
        if (el.classList.contains('slide-quote') || el.classList.contains('about-text-fade')) { 
          wrapSentences(el, 220); 
        } 
        else { 
          wrapHeadingWords(el, 100); 
        }
      });

      function reveal(entries: any, obs: any) {
        entries.forEach((e: any) => {
          if (!e.isIntersecting) return;
          const el = e.target;
          
          if (el.classList.contains('heading-anim')) {
            el.querySelectorAll('.word-unit,.sentence-unit').forEach((w: any) => {
              w.style.opacity = '1'; w.style.filter = 'blur(0)'; w.style.transform = 'translateY(0)';
            });
            obs.unobserve(el); return;
          }
          
          if (el.classList.contains('roadmap-node')) {
            const d = parseInt(el.dataset.delay || '0');
            setTimeout(() => el.classList.add('visible'), d);
            obs.unobserve(el); return;
          }

          const delay = parseInt(el.dataset.delay || 0);
          setTimeout(() => el.classList.add('visible'), delay);
          obs.unobserve(el);
        });
      }

      const io = new IntersectionObserver(reveal, { threshold: .05, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
      document.querySelectorAll('.heading-anim').forEach(el => io.observe(el));
      document.querySelectorAll('.card-anim').forEach(el => io.observe(el));
      document.querySelectorAll('.work-anim').forEach(el => io.observe(el));
      document.querySelectorAll('.about-info-card').forEach(el => io.observe(el));
      document.querySelectorAll('.roadmap-node').forEach(el => io.observe(el));
    })();
  </script>
</Layout>