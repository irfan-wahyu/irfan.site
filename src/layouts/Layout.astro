---
import BaseHead from '../components/BaseHead.astro';
import Cursor from '../components/Cursor.astro';
import Footer from '../components/Footer.astro';

// Mengambil base path secara otomatis dari sistem Astro
const base = import.meta.env.BASE_URL;

export interface Props {
  title: string;
  description?: string;
  pageStyle?: string;
}
const { title, description, pageStyle } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  
  <!-- CSS pageStyle jika ada -->
  {pageStyle && <link rel="stylesheet" href={`${base}${pageStyle.replace(/^\//, '')}`} />}
  
  <!-- CSS Global yang pasti jalan -->
  <link rel="stylesheet" href={`${base}styles/global.css`}>
</head>
<body>
  <Cursor />
  <slot />
  <Footer />
</body>
</html>